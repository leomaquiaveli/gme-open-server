# Obrigatório
API_KEY=sua_chave_aqui

# Storage — escolha um
STORAGE_TYPE=local                    # "local" para dev, "gcs" para produção
LOCAL_STORAGE_PATH=C:\tmp\gme         # necessário se STORAGE_TYPE=local

# GCS — necessário se STORAGE_TYPE=gcs
BUCKET_NAME=                          # nome do bucket GCS

# Credenciais GCS — duas opções, escolha uma:
# Opção 1 (recomendada para Cloud Run): deixe em branco.
#   O servidor usa Application Default Credentials (ADC) via metadata server do GCP.
#   Basta associar uma Service Account com permissão "Storage Object Admin" ao Cloud Run service.
#   Nenhuma chave precisa ser armazenada — zero segredos expostos.
# Opção 2 (para VMs fora do GCP ou dev local): cole o JSON completo da service account key.
SERVICE_ACCOUNT_CREDENTIALS=

# Performance
MAX_CONCURRENT_JOBS=8                 # jobs FFmpeg simultâneos — default: número de vCPUs da máquina (auto)
CACHE_TTL_MINUTES=60                  # TTL do file cache em minutos (default: 60)
ENCODER=libx264                       # "libx264" força CPU, "" auto-detecta GPU
FFMPEG_THREADS=4                      # threads por encode (0 = auto; no Windows use 4 para evitar malloc)
RENDER_TIMEOUT_MINUTES=5              # timeout por job de renderização (default: 5). Aumente para vídeos longos. No Cloud Run mantenha baixo.

# Servidor
PORT=8080
